{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "declaration": true,
    "declarationDir": "./dist/types",
    "outDir": "./dist",
    "rootDir": "./lib",
    "types": ["node"],
    "lib": ["ES2022"]
  },
  "include": ["lib/**/*.ts"],
  "exclude": ["node_modules", "dist", "test", "build"]
}
