{
  "name": "mechatron",
  "version": "0.0.0",
  "description": "Node.js native addon for desktop automation (keyboard, mouse, screen, process, memory, window)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "workspaces": [
    "packages/mechatron-types",
    "packages/mechatron-keyboard",
    "packages/mechatron-mouse",
    "packages/mechatron-clipboard",
    "packages/mechatron-screen",
    "packages/mechatron-window",
    "packages/mechatron-process",
    "packages/mechatron-memory",
    "packages/mechatron-robot-js"
  ],
  "scripts": {
    "build:native": "cd native-rs && cargo build --release",
    "build": "tsc --build",
    "test": "node test/test.js types timer",
    "test:ci": "node test/test.js types"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/p120ph37/mechatron.git"
  },
  "author": "Aaron Meriwether",
  "license": "MIT",
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "files": [
    "dist/"
  ],
  "dependencies": {
    "mechatron-types": "*",
    "mechatron-keyboard": "*",
    "mechatron-mouse": "*",
    "mechatron-clipboard": "*",
    "mechatron-screen": "*",
    "mechatron-window": "*",
    "mechatron-process": "*",
    "mechatron-memory": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "pngjs": "^6.0.0",
    "readline-sync": "~1.4",
    "sprintf-js": "~1.1",
    "typescript": "^5.7.0"
  }
}
