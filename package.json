{
  "name": "mechatron",
  "version": "0.0.0",
  "description": "Node.js native addon for desktop automation (keyboard, mouse, screen, process, memory, window)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "bun": {
        "types": "./lib/index.ts",
        "default": "./lib/index.ts"
      },
      "import": "./dist/index.js",
      "require": "./dist/index.js",
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./package.json": "./package.json"
  },
  "workspaces": [
    "packages/@mechatronic/napi-keyboard",
    "packages/@mechatronic/napi-mouse",
    "packages/@mechatronic/napi-clipboard",
    "packages/@mechatronic/napi-screen",
    "packages/@mechatronic/napi-window",
    "packages/@mechatronic/napi-process",
    "packages/@mechatronic/napi-memory",
    "packages/@mechatronic/ffi-keyboard",
    "packages/@mechatronic/ffi-mouse",
    "packages/@mechatronic/ffi-clipboard",
    "packages/@mechatronic/ffi-screen",
    "packages/@mechatronic/ffi-window",
    "packages/@mechatronic/ffi-process",
    "packages/@mechatronic/ffi-memory",
    "packages/mechatron-robot-js"
  ],
  "scripts": {
    "build:native": "cd napi && cargo build --release",
    "build:ffi": "cd ffi && cargo build --release",
    "build:test-helper": "clang -O2 test/memory-child.c -o test/memory-child",
    "build": "tsc",
    "test": "node test/test.js types timer",
    "test:all": "node test/test.js all"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/p120ph37/mechatron.git"
  },
  "author": "Aaron Meriwether",
  "license": "MIT",
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "files": [
    "dist/",
    "lib/"
  ],
  "optionalDependencies": {
    "@mechatronic/napi-clipboard": "*",
    "@mechatronic/napi-keyboard": "*",
    "@mechatronic/napi-memory": "*",
    "@mechatronic/napi-mouse": "*",
    "@mechatronic/napi-process": "*",
    "@mechatronic/napi-screen": "*",
    "@mechatronic/napi-window": "*",
    "@mechatronic/ffi-clipboard": "*",
    "@mechatronic/ffi-keyboard": "*",
    "@mechatronic/ffi-memory": "*",
    "@mechatronic/ffi-mouse": "*",
    "@mechatronic/ffi-process": "*",
    "@mechatronic/ffi-screen": "*",
    "@mechatronic/ffi-window": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "c8": "^11.0.0",
    "pngjs": "^6.0.0",
    "readline-sync": "~1.4",
    "sprintf-js": "~1.1",
    "typescript": "^5.7.0"
  }
}
