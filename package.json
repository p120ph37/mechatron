{
  "name": "mechatron",
  "version": "0.0.0",
  "description": "Node.js native addon for desktop automation (keyboard, mouse, screen, process, memory, window)",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "workspaces": [
    "packages/@mechatronic/napi-keyboard",
    "packages/@mechatronic/napi-mouse",
    "packages/@mechatronic/napi-clipboard",
    "packages/@mechatronic/napi-screen",
    "packages/@mechatronic/napi-window",
    "packages/@mechatronic/napi-process",
    "packages/@mechatronic/napi-memory",
    "packages/mechatron-robot-js"
  ],
  "scripts": {
    "build:native": "cd napi && cargo build --release",
    "build": "tsc",
    "test": "node test/test.js types timer",
    "test:all": "node test/test.js all"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/p120ph37/mechatron.git"
  },
  "author": "Aaron Meriwether",
  "license": "MIT",
  "os": [
    "linux",
    "darwin",
    "win32"
  ],
  "files": [
    "dist/"
  ],
  "optionalDependencies": {
    "@mechatronic/napi-keyboard": "*",
    "@mechatronic/napi-mouse": "*",
    "@mechatronic/napi-clipboard": "*",
    "@mechatronic/napi-screen": "*",
    "@mechatronic/napi-window": "*",
    "@mechatronic/napi-process": "*",
    "@mechatronic/napi-memory": "*"
  },
  "devDependencies": {
    "@types/node": "^25.5.2",
    "pngjs": "^6.0.0",
    "readline-sync": "~1.4",
    "sprintf-js": "~1.1",
    "typescript": "^5.7.0"
  }
}
